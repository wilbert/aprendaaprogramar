# Copy to the server as shared/.env (Capistrano symlinks it into each release,
# and the systemd unit loads it as EnvironmentFile). Do NOT commit the real .env.

# Required in production. Generate with: bin/rails secret
SECRET_KEY_BASE=

# Your public domain. Enables Host-header authorization for that host (and its
# subdomains). Leave unset to disable host checks (e.g. when testing by IP).
APP_HOST=

# Puma tuning (optional; defaults shown).
RAILS_MAX_THREADS=5
WEB_CONCURRENCY=2

# Set to "true" to have Rails force http->https (nginx already redirects, so
# usually leave false to avoid double-handling).
FORCE_SSL=false

# Log verbosity (debug, info, warn, error).
RAILS_LOG_LEVEL=info
